LINE_HEAVY_TRIPLE_DASH_HORIZONTAL:    rune : '┅'
LINE_LIGHT_QUADRUPLE_DASH_HORIZONTAL: rune : '┈'
LINE_HEAVY_QUADRUPLE_DASH_HORIZONTAL: rune : '┉'

LINE_TOP_RIGHT:         rune : '┐'
LINE_ROUNDED_TOP_RIGHT: rune : '╮'
LINE_DOUBLE_TOP_RIGHT:  rune : '╗'
LINE_THICK_TOP_RIGHT:   rune : '┓'

LINE_TOP_LEFT:         rune : '┌'
LINE_ROUNDED_TOP_LEFT: rune : '╭'
LINE_DOUBLE_TOP_LEFT:  rune : '╔'
LINE_THICK_TOP_LEFT:   rune : '┏'

LINE_BOTTOM_RIGHT:         rune : '┘'
