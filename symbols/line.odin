LINE_LIGHT_DOUBLE_DASH_VERTICAL:    rune : '╎'
LINE_HEAVY_DOUBLE_DASH_VERTICAL:    rune : '╏'
LINE_LIGHT_TRIPLE_DASH_VERTICAL:    rune : '┆'
